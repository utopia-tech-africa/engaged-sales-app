generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  promoter
  merchandizer
  supervisor
  admin
}

enum Gender {
  male
  female
  other
}

enum AuthProvider {
  credentials
  google
}

model User {
  id         String        @id @default(cuid())
  fullName   String
  email      String?       @unique
  phone      String        @unique
  uniqueCode String        @unique
  role       UserRole
  isActive   Boolean       @default(true)
  authProvider AuthProvider @default(credentials)
  googleSub  String?       @unique
  gender     Gender?
  regionId   String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  region     Region?       @relation(fields: [regionId], references: [id], onDelete: SetNull)
  sessions   AuthSession[]
  locations  LocationPing[]

  @@index([regionId])
}

/// Sales territory (e.g. Nairobi West). Referenced by User.regionId.
model Region {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  replacedById     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LocationPing {
  id        String   @id @default(cuid())
  userId    String
  latitude  Float
  longitude Float
  recordedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt(sort: Desc)])
}

model OauthNonce {
  id        String   @id @default(cuid())
  nonce     String   @unique
  provider  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

/// Circular work area for sign-in geofencing. Admins manage rows via /admin/geofences.
model Geofence {
  id              String   @id @default(cuid())
  label           String
  centerLatitude  Float
  centerLongitude Float
  radiusMeters    Float
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
