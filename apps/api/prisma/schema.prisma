generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  promoter
  merchandizer
  supervisor
  admin
}

enum Gender {
  male
  female
  other
}

enum AuthProvider {
  credentials
  google
}

enum AttendanceKind {
  clock_in
  clock_out
}

enum ReportFrequency {
  daily
  weekly
}

model User {
  id         String        @id @default(cuid())
  fullName   String
  email      String?       @unique
  phone      String        @unique
  uniqueCode String        @unique
  role       UserRole
  isActive   Boolean       @default(true)
  authProvider AuthProvider @default(credentials)
  googleSub  String?       @unique
  gender     Gender?
  regionId   String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  region     Region?       @relation(fields: [regionId], references: [id], onDelete: SetNull)
  sessions   AuthSession[]
  locations  LocationPing[]
  activationRosters ActivationRoster[]
  sales      Sale[]
  outletVisits OutletVisit[]
  stockPickups StockPickup[]
  reportConfigs ReportConfig[]

  @@index([regionId])
}

/// Sales territory (e.g. Nairobi West). Referenced by User.regionId.
model Region {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users        User[]
  activations  Activation[]
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  replacedById     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LocationPing {
  id         String   @id @default(cuid())
  userId     String
  /// Whether this ping is a field clock-in or clock-out (legacy rows default to clock_in).
  attendanceKind AttendanceKind @default(clock_in)
  /// Optional matched geofence/outlet id used for outlet-distance validation.
  geofenceId String?
  /// Distance in meters from ping point to matched geofence center.
  distanceToGeofenceMeters Float?
  /// Duration from previous ping while still on same matched geofence.
  dwellSecondsAtGeofence Int?
  latitude   Float
  longitude  Float
  /// Human-readable place from reverse geocoding when the ping was saved (nullable for legacy rows).
  placeLabel String?
  /// Stored selfie blob for attendance verification (JPEG/PNG); omit from list APIs.
  selfieMimeType String?
  selfieImage    Bytes?
  /// Mirrors presence of `selfieImage` without loading the blob in history queries.
  hasSelfieVerification Boolean @default(false)
  recordedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt(sort: Desc)])
  @@index([geofenceId, recordedAt(sort: Desc)])
}

model OauthNonce {
  id        String   @id @default(cuid())
  nonce     String   @unique
  provider  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

/// Field campaign / activation (products + promoter roster). Managed via /admin/activations.
model Activation {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  regionId    String?
  startsAt    DateTime
  endsAt      DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  region      Region?  @relation(fields: [regionId], references: [id], onDelete: SetNull)
  products    ActivationProduct[]
  roster      ActivationRoster[]
  sales       Sale[]
  stockPickups StockPickup[]

  @@index([regionId])
  @@index([startsAt])
}

model ActivationProduct {
  id           String     @id @default(cuid())
  activationId String
  name         String
  sku          String?
  quantity     Int        @default(1)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  activation   Activation @relation(fields: [activationId], references: [id], onDelete: Cascade)
  saleItems    SaleItem[]
  stockPickupItems StockPickupItem[]

  @@index([activationId])
}

/// Promoter sale event (header + line items). See BACKEND_PRD §7.4.
model Sale {
  id             String   @id @default(cuid())
  userId         String
  activationId   String
  /// When set, duplicate POST with same key returns the existing sale (24h cache optional; unique enforces forever per user).
  idempotencyKey String?
  latitude       Float?
  longitude      Float?
  createdAt      DateTime @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  activation     Activation   @relation(fields: [activationId], references: [id], onDelete: Cascade)
  items          SaleItem[]

  @@unique([userId, idempotencyKey])
  @@index([activationId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model SaleItem {
  id        String @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  /// Optional line price at time of sale (ActivationProduct has no price field yet).
  unitPrice Float?
  sale      Sale              @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   ActivationProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
}

model ActivationRoster {
  id           String     @id @default(cuid())
  activationId String
  userId       String
  createdAt    DateTime   @default(now())
  activation   Activation @relation(fields: [activationId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activationId, userId])
  @@index([userId])
}

/// Circular work area for sign-in geofencing. Admins manage rows via /admin/geofences.
model Geofence {
  id              String   @id @default(cuid())
  label           String
  centerLatitude  Float
  centerLongitude Float
  radiusMeters    Float
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Trade outlet managed by operations and visited by field staff.
model Outlet {
  id               String   @id @default(cuid())
  name             String
  category         String
  distributorName  String
  locationArea     String
  contactName      String?
  contactPhone     String?
  contactEmail     String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  visits           OutletVisit[]
}

/// Visit/check-in execution at an outlet (photo + trade metrics).
model OutletVisit {
  id                        String   @id @default(cuid())
  outletId                  String
  userId                    String
  latitude                  Float
  longitude                 Float
  outletPhotoMimeType       String?
  outletPhotoImage          Bytes?
  hasOutletPhoto            Boolean  @default(false)
  stockAvailabilityNotes    String?
  salesMadeNotes            String?
  consumerEngagementNotes   String?
  visibilityExecutionNotes  String?
  checkedInAt               DateTime @default(now())
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  outlet                    Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([outletId, checkedInAt(sort: Desc)])
  @@index([userId, checkedInAt(sort: Desc)])
}

/// Stock receipt event when field staff picks inventory from a distributor.
model StockPickup {
  id              String   @id @default(cuid())
  userId          String
  activationId    String
  distributorName String
  pickedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activation      Activation @relation(fields: [activationId], references: [id], onDelete: Cascade)
  items           StockPickupItem[]

  @@index([userId, pickedAt(sort: Desc)])
  @@index([activationId, pickedAt(sort: Desc)])
}

/// Line item for picked stock (SKU, quantity, and distributor cost price).
model StockPickupItem {
  id         String   @id @default(cuid())
  pickupId   String
  productId  String
  quantity   Int
  costPrice  Float
  createdAt  DateTime @default(now())
  pickup     StockPickup      @relation(fields: [pickupId], references: [id], onDelete: Cascade)
  product    ActivationProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([pickupId])
  @@index([productId])
}

model ReportConfig {
  id               String   @id @default(cuid())
  key              String   @unique
  timezone         String   @default("UTC")
  dailyEnabled     Boolean  @default(false)
  dailyCron        String   @default("0 0 19 * * *")
  weeklyEnabled    Boolean  @default(false)
  weeklyCron       String   @default("0 0 19 * * 1")
  dailyLastSentAt  DateTime?
  weeklyLastSentAt DateTime?
  createdByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdByUser    User?    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  recipients       ReportRecipient[]
}

model ReportRecipient {
  id          String   @id @default(cuid())
  reportConfigId String
  email       String
  frequency   ReportFrequency @default(daily)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reportConfig ReportConfig @relation(fields: [reportConfigId], references: [id], onDelete: Cascade)

  @@index([reportConfigId])
  @@unique([reportConfigId, email, frequency])
}
