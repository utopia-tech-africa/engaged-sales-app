generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  promoter
  merchandizer
  supervisor
  admin
}

enum Gender {
  male
  female
  other
}

enum AuthProvider {
  credentials
  google
}

model User {
  id         String        @id @default(cuid())
  fullName   String
  email      String?       @unique
  phone      String        @unique
  uniqueCode String        @unique
  role       UserRole
  isActive   Boolean       @default(true)
  authProvider AuthProvider @default(credentials)
  googleSub  String?       @unique
  gender     Gender?
  regionId   String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  region     Region?       @relation(fields: [regionId], references: [id], onDelete: SetNull)
  sessions   AuthSession[]
  locations  LocationPing[]
  activationRosters ActivationRoster[]

  @@index([regionId])
}

/// Sales territory (e.g. Nairobi West). Referenced by User.regionId.
model Region {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users        User[]
  activations  Activation[]
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  replacedById     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LocationPing {
  id         String   @id @default(cuid())
  userId     String
  latitude   Float
  longitude  Float
  /// Human-readable place from reverse geocoding when the ping was saved (nullable for legacy rows).
  placeLabel String?
  recordedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt(sort: Desc)])
}

model OauthNonce {
  id        String   @id @default(cuid())
  nonce     String   @unique
  provider  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

/// Field campaign / activation (products + promoter roster). Managed via /admin/activations.
model Activation {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  regionId    String?
  startsAt    DateTime
  endsAt      DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  region      Region?  @relation(fields: [regionId], references: [id], onDelete: SetNull)
  products    ActivationProduct[]
  roster      ActivationRoster[]

  @@index([regionId])
  @@index([startsAt])
}

model ActivationProduct {
  id           String     @id @default(cuid())
  activationId String
  name         String
  sku          String?
  quantity     Int        @default(1)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  activation   Activation @relation(fields: [activationId], references: [id], onDelete: Cascade)

  @@index([activationId])
}

model ActivationRoster {
  id           String     @id @default(cuid())
  activationId String
  userId       String
  createdAt    DateTime   @default(now())
  activation   Activation @relation(fields: [activationId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activationId, userId])
  @@index([userId])
}

/// Circular work area for sign-in geofencing. Admins manage rows via /admin/geofences.
model Geofence {
  id              String   @id @default(cuid())
  label           String
  centerLatitude  Float
  centerLongitude Float
  radiusMeters    Float
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
