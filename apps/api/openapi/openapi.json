              }
            }
          },
          "401": {
            "description": "Missing or invalid JWT token"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Record user location",
        "tags": ["Me"]
      }
    }
  },
  "info": {
    "title": "Engaged Sales API",
    "description": "API documentation for Engaged Sales backend",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "SignUpDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "Jamal Salim",
            "description": "Full name of the user"
          },
          "phone": {
            "type": "string",
            "example": "+254712345678",
            "description": "E.164 phone number"
          },
          "gender": {
            "type": "string",
            "example": "male",
            "enum": ["male", "female", "other"]
          },
          "regionId": {
            "type": "string",
            "example": "nairobi-west",
            "description": "Optional sales region id"
          }
        },
        "required": ["fullName", "phone", "gender"]
      },
      "SignInDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+254712345678",
            "description": "Registered phone number"
          },
          "uniqueCode": {
            "type": "string",
            "example": "P-12ab34cd",
            "description": "Unique promoter code"
          },
          "role": {
            "type": "string",
            "example": "promoter",
            "enum": ["promoter", "merchandizer", "supervisor", "admin"]
          },
          "latitude": {
            "type": "number",
            "description": "Device latitude (decimal degrees). For promoters and merchandizers: required when at least one geofence is active (send with longitude). Supervisors and admins may omit coordinates.",
            "example": -1.286389
          },
          "longitude": {
            "type": "number",
            "description": "Device longitude (decimal degrees). For promoters and merchandizers: required with latitude when geofencing is enforced. Supervisors and admins may omit.",
            "example": 36.817223
          }
        },
        "required": ["phone", "uniqueCode", "role"]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "example": "cmadfk8m50000ii9l5g8qxh4d.6Mcpfd1xK8h6c7Iu4eD9TzLQkKkL4aY5",
            "description": "Refresh token in <sessionId>.<secret> format"
          }
        },
        "required": ["refreshToken"]
      },
      "OauthCallbackDto": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "example": "google",
            "enum": ["google"]
          },
          "code": {
            "type": "string",
            "example": "4/0AQSTgQF...",
            "description": "Authorization code from Google callback"
          },
          "redirectUri": {
            "type": "string",
            "example": "http://localhost:3000/auth/google/callback"
          },
          "state": {
            "type": "string",
            "example": "eyJub25jZSI6Ii4uLiJ9.R5m...",
            "description": "Signed OAuth state from start endpoint"
          },
          "latitude": {
            "type": "number",
            "description": "Device latitude. For promoters/merchandizers when geofencing is active, send with longitude. Supervisors/admins may omit.",
            "example": -1.286389
          },
          "longitude": {
            "type": "number",
            "description": "Device longitude (pair with latitude when required for field roles).",
            "example": 36.817223
          }
        },
        "required": ["provider", "code", "redirectUri", "state"]
      },
      "OauthStartDto": {
        "type": "object",
        "properties": {
          "redirectUri": {
            "type": "string",
            "example": "http://localhost:3000/auth/google/callback",
            "description": "Frontend redirect URI registered with Google OAuth"
          }
        },
        "required": ["redirectUri"]
      },
      "ProfileCompletionDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "jamal@example.com"
          },
          "phone": {
            "type": "string",
            "example": "+254712345678"
          },
          "gender": {
            "type": "string",
            "example": "male",
            "enum": ["male", "female", "other"]
          },
          "fullName": {
            "type": "string",
            "example": "Jamal Salim"
          },
          "regionId": {
            "type": "string",
            "example": "nairobi-west"
          }
        }
      },
      "RevokeUserSessionsDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "example": "cmad4p0bo0000iib0i0l9e8wk",
            "description": "Target user id whose sessions should be revoked"
          }
        },
        "required": ["userId"]
      },
      "SignOutDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "example": "cmadfk8m50000ii9l5g8qxh4d.6Mcpfd1xK8h6c7Iu4eD9TzLQkKkL4aY5",
            "description": "Refresh token to revoke the session"
          }
        },
        "required": ["refreshToken"]
      },
      "UpdateMeDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "Jamal Salim"
          },
          "gender": {
            "type": "string",
            "example": "male",
            "enum": ["male", "female", "other"]
          },
          "regionId": {
            "type": "string",
            "example": "nairobi-west"
          }
        }
      },
      "UpdateLocationDto": {
        "type": "object",
        "properties": {
          "latitude": {
            "type": "number",
            "example": -1.286389,
            "description": "Latitude in decimal degrees"
          },
          "longitude": {
            "type": "number",
            "example": 36.817223,
            "description": "Longitude in decimal degrees"
          }
        },
        "required": ["latitude", "longitude"]
      }
    }
  }
}
