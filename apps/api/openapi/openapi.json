{
  "openapi": "3.0.0",
  "paths": {
    "/auth/sign-up": {
      "post": {
        "description": "Creates a new promoter user and returns access/refresh tokens.",
        "operationId": "Auth_signUp",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpDto"
              },
              "examples": {
                "default": {
                  "value": {
                    "fullName": "Jamal Salim",
                    "phone": "+254712345678",
                    "gender": "male",
                    "regionId": "nairobi-west"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "user": {
                      "id": "cmad4p0bo0000iib0i0l9e8wk",
                      "fullName": "Jamal Salim",
                      "email": null,
                      "phone": "+254712345678",
                      "uniqueCode": "P-12ab34cd",
                      "role": "promoter",
                      "gender": "male",
                      "regionId": "nairobi-west",
                      "authProvider": "credentials",
                      "requiresProfileCompletion": false,
                      "missingProfileFields": [],
                      "createdAt": "2026-05-08T18:00:00.000Z",
                      "updatedAt": "2026-05-08T18:00:00.000Z"
                    },
                    "accessToken": "<jwt>",
                    "refreshToken": "<sessionId>.<secret>",
                    "expiresIn": 900
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failed or request body missing"
          },
          "403": {
            "description": "Too many auth attempts from this IP"
          },
          "409": {
            "description": "User already exists"
          }
        },
        "summary": "Register a promoter account",
        "tags": ["Auth"]
      }
    },
    "/auth/signup": {
      "post": {
        "description": "Deprecated alias of /auth/sign-up; emits deprecation headers.",
        "operationId": "Auth_legacySignUp",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Same response as /auth/sign-up"
          }
        },
        "summary": "Deprecated signup alias",
        "tags": ["Auth"]
      }
    },
    "/auth/sign-in": {
      "post": {
        "description": "Authenticates a user and returns a fresh token pair.",
        "operationId": "Auth_signIn",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignInDto"
              },
              "examples": {
                "default": {
                  "value": {
                    "phone": "+254712345678",
                    "uniqueCode": "P-12ab34cd",
                    "role": "promoter"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sign-in successful",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "user": {
                      "id": "cmad4p0bo0000iib0i0l9e8wk",
                      "fullName": "Jamal Salim",
                      "email": null,
                      "phone": "+254712345678",
                      "uniqueCode": "P-12ab34cd",
                      "role": "promoter",
                      "gender": "male",
                      "regionId": "nairobi-west",
                      "authProvider": "credentials",
                      "requiresProfileCompletion": false,
                      "missingProfileFields": []
                    },
                    "accessToken": "<jwt>",
                    "refreshToken": "<sessionId>.<secret>",
                    "expiresIn": 900
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failed or request body missing"
          },
          "401": {
            "description": "Invalid credentials"
          },
          "403": {
            "description": "Rate limit exceeded, phone temporarily locked, or sign-in blocked outside the authorized work area (geofence)"
          }
        },
        "summary": "Sign in with phone, code, and role",
        "tags": ["Auth"]
      }
    },
    "/auth/login": {
      "post": {
        "description": "Deprecated alias of /auth/sign-in; emits deprecation headers.",
        "operationId": "Auth_legacySignIn",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignInDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Same response as /auth/sign-in"
          }
        },
        "summary": "Deprecated login alias",
        "tags": ["Auth"]
      }
    },
    "/auth/refresh": {
      "post": {
        "description": "Rotates refresh token session and returns a new token pair.",
        "operationId": "Auth_refresh",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token refresh successful",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "accessToken": "<jwt>",
                    "refreshToken": "<newSessionId>.<newSecret>",
                    "expiresIn": 900
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failed or request body missing"
          },
          "401": {
            "description": "Invalid, revoked, expired, or reused refresh token"
          },
          "403": {
            "description": "Refresh rate limit exceeded"
          }
        },
        "summary": "Rotate refresh token and issue new access token",
        "tags": ["Auth"]
      }
    },
    "/auth/oauth/callback": {
      "post": {
        "description": "Validates state/nonce, exchanges Google code, and returns token pair.",
        "operationId": "Auth_oauthCallback",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OauthCallbackDto"
              },
              "examples": {
                "default": {
                  "value": {
                    "provider": "google",
                    "code": "4/0AQSTgQF...",
                    "redirectUri": "http://localhost:3000/auth/google/callback",
                    "state": "eyJub25jZSI6Ii4uLiJ9.R5m..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OAuth callback successful",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "user": {
                      "id": "cmad4p0bo0000iib0i0l9e8wk",
                      "fullName": "Jamal Salim",
                      "email": "jamal@example.com",
                      "phone": "pending-a8e4c2f7f9d1",
                      "uniqueCode": "P-12ab34cd",
                      "role": "promoter",
                      "gender": null,
                      "regionId": null,
                      "authProvider": "google",
                      "requiresProfileCompletion": true,
                      "missingProfileFields": ["phone", "regionId"]
                    },
                    "accessToken": "<jwt>",
                    "refreshToken": "<sessionId>.<secret>",
                    "expiresIn": 900
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failed or malformed body"
          },
          "401": {
            "description": "Invalid OAuth state, nonce, or Google code"
          },
          "403": {
            "description": "OAuth callback rate limit exceeded"
          }
        },
        "summary": "Handle Google OAuth callback",
        "tags": ["Auth"]
      }
    },
    "/auth/oauth/google/start": {
      "post": {
        "description": "Creates state/nonce and returns Google authorization URL.",
        "operationId": "Auth_startGoogleOauth",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OauthStartDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OAuth authorization payload",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "provider": "google",
                    "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth?client_id=...&redirect_uri=...&state=...",
                    "state": "eyJub25jZSI6Ii4uLiJ9.R5m..."
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failed or request body missing"
          },
          "403": {
            "description": "OAuth start rate limit exceeded"
          }
        },
        "summary": "Create Google OAuth authorization URL",
        "tags": ["Auth"]
      }
    },
    "/auth/profile-completion": {
      "post": {
        "description": "Updates optional profile fields for the authenticated user.",
        "operationId": "Auth_profileCompletion",
