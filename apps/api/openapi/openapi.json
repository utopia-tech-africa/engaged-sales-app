    "/admin/geofences": {
      "get": {
        "description": "Returns all geofence definitions for the operations dashboard.",
        "operationId": "AdminGeofence_listGeofences",
        "parameters": [],
        "responses": {
          "200": {
            "description": "List of geofences"
          },
