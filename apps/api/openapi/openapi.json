            "description": "Sessions revoked successfully"
          },
          "401": {
            "description": "Missing or invalid JWT token"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Revoke all other sessions for current user",
        "tags": ["Auth"]
      }
    },
